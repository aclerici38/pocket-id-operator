#!/usr/bin/env bash
#MISE description="Generate CRDs, RBAC and webhook manifests, and sync them into the chart"
set -euo pipefail

controller-gen rbac:roleName=pocket-id-operator-manager-role crd webhook \
  paths="./..." output:crd:artifacts:config=config/crd/bases

rm -rf charts/pocket-id-operator/crds
mkdir -p charts/pocket-id-operator/crds
cp config/crd/bases/*.yaml charts/pocket-id-operator/crds/

awk '/^metadata:$/ {
  print
  print "  labels:"
  print "    {{- include \"chart.labels\" . | nindent 4 }}"
  next
} 1' config/rbac/role.yaml > charts/pocket-id-operator/templates/rbac/manager-role.yaml
