#!/usr/bin/env bash
#MISE description="Generate JSON schemas from CRDs for yaml-language-server support"
#MISE depends=["manifests"]
set -euo pipefail

command -v crd-schema-publisher >/dev/null 2>&1 || { echo "Error: crd-schema-publisher not found. Run 'mise install'."; exit 1; }

mkdir -p dist/schemas
rm -f dist/schemas/*.json

# crd-schema-publisher writes group-scoped subdirs (<group>/<kind>_<version>.json)
# plus a kubeconform "master-standalone" copy and a _meta manifest. Convert into a
# staging dir and flatten the group-scoped schemas into dist/schemas/ to preserve
# the published flat layout (see docs/README.md).
stage="$(mktemp -d)"
trap 'rm -rf "$stage"' EXIT
crd-schema-publisher convert -d config/crd/bases -o "$stage"
cp "$stage"/pocketid.internal/*.json dist/schemas/

# Build the subchart (instance) schema first so it can be embedded into the
# operator schema below.
jq --slurpfile instance dist/schemas/pocketidinstance_v1alpha1.json \
  --slurpfile user dist/schemas/pocketiduser_v1alpha1.json \
  --slurpfile usergroup dist/schemas/pocketidusergroup_v1alpha1.json \
  --slurpfile oidcclient dist/schemas/pocketidoidcclient_v1alpha1.json \
  --slurpfile api dist/schemas/pocketidapi_v1alpha1.json \
  '.properties.instance.then.properties.spec = $instance[0].properties.spec | .properties.users.items.properties.spec = $user[0].properties.spec | .properties.userGroups.items.properties.spec = $usergroup[0].properties.spec | .properties.oidcClients.items.properties.spec = $oidcclient[0].properties.spec | .properties.apis.items.properties.spec = $api[0].properties.spec' \
  charts/pocket-id-instance/values.schema.skeleton.json > charts/pocket-id-instance/values.schema.json

jq --slurpfile instance dist/schemas/pocketidinstance_v1alpha1.json \
  --slurpfile user dist/schemas/pocketiduser_v1alpha1.json \
  --slurpfile usergroup dist/schemas/pocketidusergroup_v1alpha1.json \
  --slurpfile subchart charts/pocket-id-instance/values.schema.json \
  '.properties.instance.then.properties.spec = $instance[0].properties.spec | .properties.users.items.properties.spec = $user[0].properties.spec | .properties.userGroups.items.properties.spec = $usergroup[0].properties.spec | .properties["pocket-id-instance"] = $subchart[0]' \
  charts/pocket-id-operator/values.schema.skeleton.json > charts/pocket-id-operator/values.schema.json

curl -sfL https://k8s-versioned-schemas.pages.dev/helm.toolkit.fluxcd.io/helmrelease_v2.json -o /tmp/helmrelease_v2.json
for chart in pocket-id-operator pocket-id-instance; do
  jq --slurpfile values "charts/$chart/values.schema.json" \
    '.properties.spec.properties.values = $values[0]' \
    /tmp/helmrelease_v2.json > "dist/schemas/helmrelease_v2_$chart.json"
done
