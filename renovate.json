{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": [],
  "dependencyDashboard": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "platformAutomerge": true,
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "gitIgnoredAuthors": [
    "200541989\\+botthebuilder25\\[bot\\]@users\\.noreply\\.github\\.com"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["jdx/mise"],
      "schedule": ["* 0-5 * * 1"]
    },
    {
      "matchPackageNames": [
        "ghcr.io/aclerici38/pocket-id-operator",
        "ghcr.io/aclerici38/charts/pocket-id-operator"
      ],
      "groupName": "pocket-id-operator",
      "automergeType": "branch",
      "ignoreTests": true
    },
    {
      "matchPackageNames": ["ghcr.io/pocket-id/pocket-id"],
      "matchCurrentValue": "/^v/",
      "automerge": false,
      "rebaseWhen": "behind-base-branch",
      "labels": ["pocket-id-upgrade"]
    },
    {
      "description": "pocket-id `next` compatibility canary: keep the next-distroless digest current so test-e2e-next.yaml reruns on every upstream build; auto-merge a green digest bump once a month, leave a red one open as a signal.",
      "matchPackageNames": ["ghcr.io/pocket-id/pocket-id"],
      "matchCurrentValue": "/^next/",
      "groupName": "pocket-id-next",
      "labels": ["pocket-id-next-canary"],
      "pinDigests": false,
      "automerge": true,
      "platformAutomerge": false,
      "automergeSchedule": ["* 0-5 1 * *"],
      "rebaseWhen": "behind-base-branch"
    },
    {
      "matchDatasources": ["golang-version"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Go version across the project",
      "matchPackageNames": ["go", "docker.io/library/golang"],
      "groupName": "golang",
      "minimumGroupSize": 3
    },
    {
      "matchPackageNames": ["kubernetes/kubernetes", "/^k8s\\.io//", "/^sigs\\.k8s\\.io//"],
      "groupName": "kubernetes"
    },
    {
      "groupName": "go-openapi",
      "matchPackageNames": [
        "/^github\\.com/go-openapi//"
      ]
    },
    {
      "groupName": "opentelemetry",
      "matchPackageNames": [
        "/^go\\.opentelemetry\\.io//"
      ]
    },
    {
      "groupName": "golang.org/x",
      "matchPackageNames": [
        "/^golang\\.org/x//"
      ]
    },
    {
      "matchPackageNames": ["github.com/onsi/ginkgo/v2", "github.com/onsi/gomega"],
      "groupName": "onsi"
    },
    {
      "groupName": "prometheus",
      "matchPackageNames": [
        "/^github\\.com/prometheus//"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.go$/",
        "/\\.ya?ml$/",
        "/^Makefile$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?( extractVersion=(?<extractVersion>.*?))?\\n.*?[\"']?(?<currentValue>v?\\d+\\.\\d+\\.\\d+[^\"'\\s]*)[\"']?",
        "// renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?( extractVersion=(?<extractVersion>.*?))?\\n.*?[\"']?(?<currentValue>v?\\d+\\.\\d+\\.\\d+[^\"'\\s]*)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
      "extractVersionTemplate": "{{#if extractVersion}}{{{extractVersion}}}{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.go$/",
        "/\\.ya?ml$/",
        "/^Makefile$/",
        "/\\.md$/"
      ],
      "matchStrings": [
        "(?<depName>ghcr\\.io/(?:pocket-id/pocket-id|aclerici38/(?:charts/)?pocket-id-operator)):(?<currentValue>[^@\"\\s`]+)(?:@(?<currentDigest>[^\"\\s`]+))?"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
